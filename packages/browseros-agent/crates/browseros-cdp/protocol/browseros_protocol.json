{
  "version": { "major": "1", "minor": "3" },
  "domains": [
    {
      "domain": "Browser",
      "types": [
        { "id": "BrowserContextId", "type": "string" },
        { "id": "WindowId", "type": "integer" },
        { "id": "TabId", "type": "integer" },
        {
          "id": "Bounds",
          "type": "object",
          "properties": [
            { "name": "left", "type": "integer", "optional": true },
            { "name": "top", "type": "integer", "optional": true },
            { "name": "width", "type": "integer", "optional": true },
            { "name": "height", "type": "integer", "optional": true },
            { "name": "windowState", "type": "string", "optional": true }
          ]
        },
        {
          "id": "WindowInfo",
          "type": "object",
          "properties": [
            { "name": "windowId", "type": "integer" },
            { "name": "windowType", "type": "string" },
            { "name": "bounds", "$ref": "Bounds" },
            { "name": "isActive", "type": "boolean" },
            { "name": "isVisible", "type": "boolean" },
            { "name": "tabCount", "type": "integer" },
            { "name": "activeTabId", "type": "integer", "optional": true },
            { "name": "browserContextId", "type": "string", "optional": true }
          ]
        },
        {
          "id": "TabInfo",
          "type": "object",
          "properties": [
            { "name": "tabId", "type": "integer" },
            { "name": "targetId", "type": "string" },
            { "name": "url", "type": "string" },
            { "name": "title", "type": "string" },
            { "name": "isActive", "type": "boolean" },
            { "name": "isLoading", "type": "boolean" },
            { "name": "loadProgress", "type": "number" },
            { "name": "isPinned", "type": "boolean" },
            { "name": "isHidden", "type": "boolean" },
            { "name": "windowId", "type": "integer", "optional": true },
            { "name": "index", "type": "integer", "optional": true },
            { "name": "browserContextId", "type": "string", "optional": true },
            { "name": "groupId", "type": "string", "optional": true }
          ]
        },
        {
          "id": "TabGroupInfo",
          "type": "object",
          "properties": [
            { "name": "groupId", "type": "string" },
            { "name": "windowId", "type": "integer" },
            { "name": "title", "type": "string" },
            { "name": "color", "type": "string" },
            { "name": "collapsed", "type": "boolean" },
            {
              "name": "tabIds",
              "type": "array",
              "items": { "type": "integer" }
            }
          ]
        }
      ],
      "commands": [
        {
          "name": "getWindows",
          "returns": [
            {
              "name": "windows",
              "type": "array",
              "items": { "$ref": "WindowInfo" }
            }
          ]
        },
        {
          "name": "getActiveWindow",
          "returns": [
            { "name": "window", "$ref": "WindowInfo", "optional": true }
          ]
        },
        {
          "name": "createWindow",
          "parameters": [
            { "name": "url", "type": "string", "optional": true },
            { "name": "bounds", "$ref": "Bounds", "optional": true },
            { "name": "windowType", "type": "string", "optional": true },
            { "name": "hidden", "type": "boolean", "optional": true },
            { "name": "browserContextId", "type": "string", "optional": true }
          ],
          "returns": [{ "name": "window", "$ref": "WindowInfo" }]
        },
        {
          "name": "closeWindow",
          "parameters": [{ "name": "windowId", "type": "integer" }]
        },
        {
          "name": "activateWindow",
          "parameters": [{ "name": "windowId", "type": "integer" }]
        },
        {
          "name": "setWindowVisibility",
          "parameters": [
            { "name": "windowId", "type": "integer" },
            { "name": "visible", "type": "boolean" },
            { "name": "activate", "type": "boolean", "optional": true }
          ],
          "returns": [
            { "name": "window", "$ref": "WindowInfo" },
            { "name": "replaced", "type": "boolean" },
            { "name": "previousWindowId", "type": "integer" }
          ]
        },
        {
          "name": "getTabs",
          "parameters": [
            { "name": "windowId", "type": "integer", "optional": true },
            { "name": "includeHidden", "type": "boolean", "optional": true }
          ],
          "returns": [
            { "name": "tabs", "type": "array", "items": { "$ref": "TabInfo" } }
          ]
        },
        {
          "name": "getActiveTab",
          "parameters": [
            { "name": "windowId", "type": "integer", "optional": true }
          ],
          "returns": [{ "name": "tab", "$ref": "TabInfo", "optional": true }]
        },
        {
          "name": "getTabInfo",
          "parameters": [
            { "name": "targetId", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true }
          ],
          "returns": [{ "name": "tab", "$ref": "TabInfo" }]
        },
        {
          "name": "createTab",
          "parameters": [
            { "name": "url", "type": "string", "optional": true },
            { "name": "windowId", "type": "integer", "optional": true },
            { "name": "index", "type": "integer", "optional": true },
            { "name": "background", "type": "boolean", "optional": true },
            { "name": "pinned", "type": "boolean", "optional": true },
            { "name": "browserContextId", "type": "string", "optional": true }
          ],
          "returns": [{ "name": "tab", "$ref": "TabInfo" }]
        },
        {
          "name": "closeTab",
          "parameters": [
            { "name": "targetId", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true }
          ]
        },
        {
          "name": "activateTab",
          "parameters": [
            { "name": "targetId", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true }
          ]
        },
        {
          "name": "moveTab",
          "parameters": [
            { "name": "targetId", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true },
            { "name": "windowId", "type": "integer", "optional": true },
            { "name": "index", "type": "integer", "optional": true }
          ],
          "returns": [{ "name": "tab", "$ref": "TabInfo" }]
        },
        {
          "name": "showTab",
          "parameters": [
            { "name": "targetId", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true },
            { "name": "windowId", "type": "integer", "optional": true },
            { "name": "index", "type": "integer", "optional": true },
            { "name": "activate", "type": "boolean", "optional": true }
          ],
          "returns": [{ "name": "tab", "$ref": "TabInfo" }]
        },
        {
          "name": "addTabsToGroup",
          "parameters": [
            { "name": "groupId", "type": "string" },
            {
              "name": "tabIds",
              "type": "array",
              "items": { "type": "integer" }
            }
          ],
          "returns": [{ "name": "group", "$ref": "TabGroupInfo" }]
        },
        { "name": "close" },
        {
          "name": "getVersion",
          "returns": [{ "name": "product", "type": "string" }]
        }
      ]
    },
    {
      "domain": "Bookmarks",
      "types": [
        {
          "id": "BookmarkNode",
          "type": "object",
          "properties": [
            { "name": "id", "type": "string" },
            { "name": "title", "type": "string" },
            { "name": "url", "type": "string", "optional": true }
          ]
        }
      ],
      "commands": [
        {
          "name": "getTree",
          "returns": [
            {
              "name": "nodes",
              "type": "array",
              "items": { "$ref": "BookmarkNode" }
            }
          ]
        }
      ]
    },
    {
      "domain": "History",
      "types": [
        {
          "id": "HistoryEntry",
          "type": "object",
          "properties": [
            { "name": "id", "type": "string", "optional": true },
            { "name": "url", "type": "string" },
            { "name": "title", "type": "string", "optional": true },
            { "name": "lastVisitTime", "type": "number", "optional": true }
          ]
        }
      ],
      "commands": [
        {
          "name": "search",
          "parameters": [
            { "name": "text", "type": "string" },
            { "name": "maxResults", "type": "integer", "optional": true }
          ],
          "returns": [
            {
              "name": "entries",
              "type": "array",
              "items": { "$ref": "HistoryEntry" }
            }
          ]
        }
      ]
    }
  ]
}
