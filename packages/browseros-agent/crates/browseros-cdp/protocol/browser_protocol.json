{
  "version": { "major": "1", "minor": "3" },
  "domains": [
    {
      "domain": "Target",
      "types": [
        {
          "id": "TargetInfo",
          "type": "object",
          "properties": [
            { "name": "targetId", "type": "string" },
            { "name": "type", "type": "string" },
            { "name": "title", "type": "string" },
            { "name": "url", "type": "string" },
            { "name": "attached", "type": "boolean" },
            { "name": "openerId", "type": "string", "optional": true },
            { "name": "canAccessOpener", "type": "boolean" },
            { "name": "openerFrameId", "type": "string", "optional": true },
            { "name": "parentFrameId", "type": "string", "optional": true },
            { "name": "browserContextId", "type": "string", "optional": true },
            { "name": "subtype", "type": "string", "optional": true },
            { "name": "tabId", "type": "integer", "optional": true },
            { "name": "windowId", "type": "integer", "optional": true }
          ]
        },
        {
          "id": "FilterEntry",
          "type": "object",
          "properties": [
            { "name": "exclude", "type": "boolean", "optional": true },
            { "name": "type", "type": "string", "optional": true }
          ]
        }
      ],
      "commands": [
        {
          "name": "attachToTarget",
          "parameters": [
            { "name": "targetId", "type": "string" },
            { "name": "flatten", "type": "boolean", "optional": true }
          ],
          "returns": [{ "name": "sessionId", "type": "string" }]
        },
        {
          "name": "detachFromTarget",
          "parameters": [
            { "name": "sessionId", "type": "string", "optional": true },
            { "name": "targetId", "type": "string", "optional": true }
          ]
        },
        {
          "name": "setAutoAttach",
          "parameters": [
            { "name": "autoAttach", "type": "boolean" },
            { "name": "waitForDebuggerOnStart", "type": "boolean" },
            { "name": "flatten", "type": "boolean", "optional": true },
            {
              "name": "filter",
              "type": "array",
              "optional": true,
              "items": { "$ref": "FilterEntry" }
            }
          ]
        },
        {
          "name": "setDiscoverTargets",
          "parameters": [
            { "name": "discover", "type": "boolean" },
            {
              "name": "filter",
              "type": "array",
              "optional": true,
              "items": { "$ref": "FilterEntry" }
            }
          ]
        },
        {
          "name": "getTargets",
          "parameters": [
            {
              "name": "filter",
              "type": "array",
              "optional": true,
              "items": { "$ref": "FilterEntry" }
            }
          ],
          "returns": [
            {
              "name": "targetInfos",
              "type": "array",
              "items": { "$ref": "TargetInfo" }
            }
          ]
        }
      ],
      "events": [
        {
          "name": "attachedToTarget",
          "parameters": [
            { "name": "sessionId", "type": "string" },
            { "name": "targetInfo", "$ref": "TargetInfo" },
            { "name": "waitingForDebugger", "type": "boolean" }
          ]
        },
        {
          "name": "detachedFromTarget",
          "parameters": [
            { "name": "sessionId", "type": "string" },
            { "name": "targetId", "type": "string", "optional": true }
          ]
        }
      ]
    },
    {
      "domain": "Page",
      "types": [
        { "id": "FrameId", "type": "string" },
        {
          "id": "Frame",
          "type": "object",
          "properties": [
            { "name": "id", "type": "string" },
            { "name": "parentId", "type": "string", "optional": true },
            { "name": "loaderId", "type": "string", "optional": true },
            { "name": "name", "type": "string", "optional": true },
            { "name": "url", "type": "string" },
            { "name": "urlFragment", "type": "string", "optional": true },
            { "name": "domainAndRegistry", "type": "string", "optional": true },
            { "name": "securityOrigin", "type": "string", "optional": true },
            { "name": "mimeType", "type": "string", "optional": true }
          ]
        },
        {
          "id": "FrameTree",
          "type": "object",
          "properties": [
            { "name": "frame", "$ref": "Frame" },
            {
              "name": "childFrames",
              "type": "array",
              "optional": true,
              "items": { "$ref": "FrameTree" }
            }
          ]
        },
        {
          "id": "Viewport",
          "type": "object",
          "properties": [
            { "name": "x", "type": "number" },
            { "name": "y", "type": "number" },
            { "name": "width", "type": "number" },
            { "name": "height", "type": "number" },
            { "name": "scale", "type": "number" }
          ]
        },
        {
          "id": "LayoutViewport",
          "type": "object",
          "properties": [
            { "name": "pageX", "type": "integer" },
            { "name": "pageY", "type": "integer" },
            { "name": "clientWidth", "type": "integer" },
            { "name": "clientHeight", "type": "integer" }
          ]
        },
        {
          "id": "VisualViewport",
          "type": "object",
          "properties": [
            { "name": "offsetX", "type": "number" },
            { "name": "offsetY", "type": "number" },
            { "name": "pageX", "type": "number" },
            { "name": "pageY", "type": "number" },
            { "name": "clientWidth", "type": "number" },
            { "name": "clientHeight", "type": "number" },
            { "name": "scale", "type": "number" },
            { "name": "zoom", "type": "number", "optional": true }
          ]
        }
      ],
      "commands": [
        { "name": "enable" },
        {
          "name": "navigate",
          "parameters": [{ "name": "url", "type": "string" }],
          "returns": [
            { "name": "frameId", "type": "string", "optional": true },
            { "name": "loaderId", "type": "string", "optional": true },
            { "name": "errorText", "type": "string", "optional": true }
          ]
        },
        { "name": "reload" },
        {
          "name": "getFrameTree",
          "returns": [{ "name": "frameTree", "$ref": "FrameTree" }]
        },
        {
          "name": "getLayoutMetrics",
          "returns": [
            { "name": "layoutViewport", "$ref": "LayoutViewport" },
            { "name": "visualViewport", "$ref": "VisualViewport" },
            { "name": "contentSize", "type": "object" }
          ]
        },
        {
          "name": "captureScreenshot",
          "parameters": [
            { "name": "format", "type": "string", "optional": true },
            { "name": "quality", "type": "integer", "optional": true },
            { "name": "fromSurface", "type": "boolean", "optional": true },
            {
              "name": "captureBeyondViewport",
              "type": "boolean",
              "optional": true
            },
            { "name": "clip", "$ref": "Viewport", "optional": true }
          ],
          "returns": [{ "name": "data", "type": "string" }]
        },
        {
          "name": "handleJavaScriptDialog",
          "parameters": [
            { "name": "accept", "type": "boolean" },
            { "name": "promptText", "type": "string", "optional": true }
          ]
        }
      ]
    },
    {
      "domain": "DOM",
      "types": [
        {
          "id": "Node",
          "type": "object",
          "properties": [
            { "name": "nodeId", "type": "integer" },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "nodeType", "type": "integer", "optional": true },
            { "name": "nodeName", "type": "string", "optional": true },
            { "name": "localName", "type": "string", "optional": true },
            { "name": "nodeValue", "type": "string", "optional": true },
            { "name": "frameId", "type": "string", "optional": true },
            { "name": "contentDocument", "$ref": "Node", "optional": true },
            {
              "name": "children",
              "type": "array",
              "optional": true,
              "items": { "$ref": "Node" }
            }
          ]
        },
        {
          "id": "BoxModel",
          "type": "object",
          "properties": [
            {
              "name": "content",
              "type": "array",
              "items": { "type": "number" }
            },
            {
              "name": "padding",
              "type": "array",
              "items": { "type": "number" }
            },
            {
              "name": "border",
              "type": "array",
              "items": { "type": "number" }
            },
            {
              "name": "margin",
              "type": "array",
              "items": { "type": "number" }
            },
            { "name": "width", "type": "integer" },
            { "name": "height", "type": "integer" }
          ]
        }
      ],
      "commands": [
        { "name": "enable" },
        {
          "name": "describeNode",
          "parameters": [
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectId", "type": "string", "optional": true },
            { "name": "depth", "type": "integer", "optional": true }
          ],
          "returns": [{ "name": "node", "$ref": "Node" }]
        },
        {
          "name": "resolveNode",
          "parameters": [
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectGroup", "type": "string", "optional": true }
          ],
          "returns": [{ "name": "object", "$ref": "Runtime.RemoteObject" }]
        },
        {
          "name": "getContentQuads",
          "parameters": [
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectId", "type": "string", "optional": true }
          ],
          "returns": [
            {
              "name": "quads",
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "number" }
              }
            }
          ]
        },
        {
          "name": "getBoxModel",
          "parameters": [
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectId", "type": "string", "optional": true }
          ],
          "returns": [{ "name": "model", "$ref": "BoxModel" }]
        },
        {
          "name": "scrollIntoViewIfNeeded",
          "parameters": [
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectId", "type": "string", "optional": true }
          ]
        },
        {
          "name": "pushNodesByBackendIdsToFrontend",
          "parameters": [
            {
              "name": "backendNodeIds",
              "type": "array",
              "items": { "type": "integer" }
            }
          ],
          "returns": [
            {
              "name": "nodeIds",
              "type": "array",
              "items": { "type": "integer" }
            }
          ]
        },
        {
          "name": "focus",
          "parameters": [{ "name": "nodeId", "type": "integer" }]
        },
        {
          "name": "setFileInputFiles",
          "parameters": [
            { "name": "files", "type": "array", "items": { "type": "string" } },
            { "name": "nodeId", "type": "integer", "optional": true },
            { "name": "backendNodeId", "type": "integer", "optional": true },
            { "name": "objectId", "type": "string", "optional": true }
          ]
        },
        {
          "name": "getFrameOwner",
          "parameters": [{ "name": "frameId", "type": "string" }],
          "returns": [
            { "name": "backendNodeId", "type": "integer" },
            { "name": "nodeId", "type": "integer", "optional": true }
          ]
        }
      ]
    },
    {
      "domain": "Accessibility",
      "types": [
        {
          "id": "AXValue",
          "type": "object",
          "properties": [
            { "name": "type", "type": "string" },
            { "name": "value", "type": "object", "optional": true }
          ]
        },
        {
          "id": "AXProperty",
          "type": "object",
          "properties": [
            { "name": "name", "type": "string" },
            { "name": "value", "$ref": "AXValue" }
          ]
        },
        {
          "id": "AXNode",
          "type": "object",
          "properties": [
            { "name": "nodeId", "type": "string" },
            { "name": "ignored", "type": "boolean", "optional": true },
            { "name": "role", "$ref": "AXValue", "optional": true },
            { "name": "name", "$ref": "AXValue", "optional": true },
            { "name": "description", "$ref": "AXValue", "optional": true },
            { "name": "value", "$ref": "AXValue", "optional": true },
            {
              "name": "properties",
              "type": "array",
              "optional": true,
              "items": { "$ref": "AXProperty" }
            },
            {
              "name": "childIds",
              "type": "array",
              "optional": true,
              "items": { "type": "string" }
            },
            { "name": "backendDOMNodeId", "type": "integer", "optional": true }
          ]
        }
      ],
      "commands": [
        { "name": "enable" },
        {
          "name": "getFullAXTree",
          "parameters": [
            { "name": "frameId", "type": "string", "optional": true }
          ],
          "returns": [
            { "name": "nodes", "type": "array", "items": { "$ref": "AXNode" } }
          ]
        }
      ]
    },
    {
      "domain": "Input",
      "commands": [
        {
          "name": "dispatchKeyEvent",
          "parameters": [
            { "name": "type", "type": "string" },
            { "name": "modifiers", "type": "integer", "optional": true },
            { "name": "text", "type": "string", "optional": true },
            { "name": "unmodifiedText", "type": "string", "optional": true },
            { "name": "keyIdentifier", "type": "string", "optional": true },
            { "name": "code", "type": "string", "optional": true },
            { "name": "key", "type": "string", "optional": true },
            {
              "name": "windowsVirtualKeyCode",
              "type": "integer",
              "optional": true
            },
            {
              "name": "nativeVirtualKeyCode",
              "type": "integer",
              "optional": true
            },
            { "name": "autoRepeat", "type": "boolean", "optional": true },
            { "name": "isKeypad", "type": "boolean", "optional": true }
          ]
        },
        {
          "name": "dispatchMouseEvent",
          "parameters": [
            { "name": "type", "type": "string" },
            { "name": "x", "type": "number" },
            { "name": "y", "type": "number" },
            { "name": "modifiers", "type": "integer", "optional": true },
            { "name": "button", "type": "string", "optional": true },
            { "name": "buttons", "type": "integer", "optional": true },
            { "name": "clickCount", "type": "integer", "optional": true },
            { "name": "deltaX", "type": "number", "optional": true },
            { "name": "deltaY", "type": "number", "optional": true }
          ]
        }
      ]
    }
  ]
}
