{
  "version": { "major": "1", "minor": "3" },
  "domains": [
    {
      "domain": "Runtime",
      "types": [
        {
          "id": "RemoteObject",
          "type": "object",
          "properties": [
            { "name": "type", "type": "string" },
            { "name": "subtype", "type": "string", "optional": true },
            { "name": "className", "type": "string", "optional": true },
            { "name": "value", "type": "object", "optional": true },
            {
              "name": "unserializableValue",
              "type": "string",
              "optional": true
            },
            { "name": "description", "type": "string", "optional": true },
            { "name": "objectId", "type": "string", "optional": true }
          ]
        },
        {
          "id": "CallArgument",
          "type": "object",
          "properties": [
            { "name": "value", "type": "object", "optional": true },
            {
              "name": "unserializableValue",
              "type": "string",
              "optional": true
            },
            { "name": "objectId", "type": "string", "optional": true }
          ]
        },
        {
          "id": "CallFrame",
          "type": "object",
          "properties": [
            { "name": "functionName", "type": "string" },
            { "name": "scriptId", "type": "string" },
            { "name": "url", "type": "string" },
            { "name": "lineNumber", "type": "integer" },
            { "name": "columnNumber", "type": "integer" }
          ]
        },
        {
          "id": "StackTrace",
          "type": "object",
          "properties": [
            { "name": "description", "type": "string", "optional": true },
            {
              "name": "callFrames",
              "type": "array",
              "items": { "$ref": "CallFrame" }
            },
            { "name": "parent", "$ref": "StackTrace", "optional": true }
          ]
        },
        {
          "id": "ExceptionDetails",
          "type": "object",
          "properties": [
            { "name": "exceptionId", "type": "integer" },
            { "name": "text", "type": "string" },
            { "name": "lineNumber", "type": "integer" },
            { "name": "columnNumber", "type": "integer" },
            { "name": "exception", "$ref": "RemoteObject", "optional": true },
            { "name": "stackTrace", "$ref": "StackTrace", "optional": true }
          ]
        }
      ],
      "commands": [
        { "name": "enable" },
        { "name": "runIfWaitingForDebugger" },
        {
          "name": "evaluate",
          "parameters": [
            { "name": "expression", "type": "string" },
            { "name": "objectGroup", "type": "string", "optional": true },
            {
              "name": "includeCommandLineAPI",
              "type": "boolean",
              "optional": true
            },
            { "name": "silent", "type": "boolean", "optional": true },
            { "name": "contextId", "type": "integer", "optional": true },
            { "name": "returnByValue", "type": "boolean", "optional": true },
            { "name": "generatePreview", "type": "boolean", "optional": true },
            { "name": "userGesture", "type": "boolean", "optional": true },
            { "name": "awaitPromise", "type": "boolean", "optional": true }
          ],
          "returns": [
            { "name": "result", "$ref": "RemoteObject" },
            {
              "name": "exceptionDetails",
              "$ref": "ExceptionDetails",
              "optional": true
            }
          ]
        },
        {
          "name": "callFunctionOn",
          "parameters": [
            { "name": "functionDeclaration", "type": "string" },
            { "name": "objectId", "type": "string", "optional": true },
            {
              "name": "arguments",
              "type": "array",
              "optional": true,
              "items": { "$ref": "CallArgument" }
            },
            { "name": "silent", "type": "boolean", "optional": true },
            { "name": "returnByValue", "type": "boolean", "optional": true },
            { "name": "awaitPromise", "type": "boolean", "optional": true },
            { "name": "userGesture", "type": "boolean", "optional": true },
            { "name": "objectGroup", "type": "string", "optional": true }
          ],
          "returns": [
            { "name": "result", "$ref": "RemoteObject" },
            {
              "name": "exceptionDetails",
              "$ref": "ExceptionDetails",
              "optional": true
            }
          ]
        },
        {
          "name": "releaseObject",
          "parameters": [{ "name": "objectId", "type": "string" }]
        },
        {
          "name": "releaseObjectGroup",
          "parameters": [{ "name": "objectGroup", "type": "string" }]
        }
      ]
    }
  ]
}
